def process_payment(chat_id, good_id, currency, message_id=None):
    goods = load_data(GOODS_FILE)
    good = goods.get(good_id)
    
    if not good or good.get('stock', 0) <= 0:
        text = "❌ Товар недоступен"
        keyboard = [[{"text": "🔙 Каталог", "callback_data": "catalog"}]]
        if message_id:
            edit_message(chat_id, message_id, text, keyboard)
        else:
            send_message(chat_id, text, keyboard)
        return
    
    users = load_data(USERS_FILE)
    user = users.get(str(chat_id))
    
    if not user:
        text = "❌ Вы не зарегистрированы!"
        if message_id:
            edit_message(chat_id, message_id, text, [[{"text": "🔙 Главное меню", "callback_data": "main"}]])
        else:
            send_message(chat_id, text)
        return
    
    price_key = f'price_{currency}'
    balance_key = f'balance_{currency}'
    price = good.get(price_key, 0)
    
    if user.get(balance_key, 0) < price:
        text = f"""❌ <b>Недостаточно средств!</b>

Ваш баланс: {user.get(balance_key, 0)} {currency}
Нужно: {price} {currency}

🪙 Купите токены в магазине!"""
        keyboard = [
            [{"text": "🪙 Купить токены", "callback_data": "tokens"}],
            [{"text": "🔙 Каталог", "callback_data": "catalog"}]
        ]
        if message_id:
            edit_message(chat_id, message_id, text, keyboard)
        else:
            send_message(chat_id, text, keyboard)
        return
    
    # Списываем средства
    user[balance_key] -= price
    save_data(USERS_FILE, users)
    
    # Уменьшаем количество товара
    goods[good_id]['stock'] -= 1
    save_data(GOODS_FILE, goods)
    
    # Создаем заказ
    orders = load_data(ORDERS_FILE)
    order_id = str(uuid.uuid4())
    access_key = str(uuid.uuid4())[:8].upper()
    
    orders[order_id] = {
        'good_id': good_id,
        'good_name': good['name'],
        'price': price,
        'currency': currency,
        'buyer_id': str(chat_id),
        'buyer_name': user.get('name', 'Пользователь'),
        'owner': good['owner'],
        'owner_contact': good['owner_contact'],
        'download_link': good['download_link'],
        'access_key': access_key,
        'date': datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
        'status': 'pending'
    }
    save_data(ORDERS_FILE, orders)
    
    text = f"""✅ <b>Заказ создан!</b>

📦 {good['name']}
💰 {price} {currency}
👤 Владелец: {good['owner']}
📱 Контакты: {good['owner_contact']}

⏳ Ожидайте подтверждения от владельца!

🔑 Ключ доступа будет выдан после подтверждения."""
    
    keyboard = [
        [{"text": "📦 Мои заказы", "callback_data": "my_orders"}],
        [{"text": "🔙 Каталог", "callback_data": "catalog"}]
    ]
    
    if message_id:
        edit_message(chat_id, message_id, text, keyboard)
    else:
        send_message(chat_id, text, keyboard)
    
    # Уведомление админу
    if not is_admin(chat_id):
        admin_text = f"""🆕 <b>Новый заказ!</b>

👤 Покупатель: {user.get('name', 'Неизвестно')}
📦 Товар: {good['name']}
💰 Цена: {price} {currency}
📅 Дата: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}

Используйте админ-панель для управления."""
