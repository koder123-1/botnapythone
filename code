def process_add_good(chat_id, text):
    if not is_admin(chat_id):
        return
    
    lines = text.strip().split('\n')
    if len(lines) < 9:
        send_message(chat_id, "❌ Неверный формат! Нужно 9 строк.")
        return
    
    try:
        name = lines[0].strip()
        description = lines[1].strip()
        price_rub = int(lines[2].strip())
        price_tokens = int(lines[3].strip())
        price_stars = int(lines[4].strip())
        stock = int(lines[5].strip())
        owner = lines[6].strip()
        owner_contact = lines[7].strip()
        download_link = lines[8].strip()
        
        goods = load_data(GOODS_FILE)
        new_id = str(max([int(k) for k in goods.keys()] + [0]) + 1)
        
        goods[new_id] = {
            'name': name,
            'description': description,
            'price_rub': price_rub,
            'price_tokens': price_tokens,
            'price_stars': price_stars,
            'stock': stock,
            'owner': owner,
            'owner_contact': owner_contact,
            'download_link': download_link
        }
        save_data(GOODS_FILE, goods)
        
        send_message(chat_id, f"✅ Товар добавлен! ID: {new_id}")
    except Exception as e:
        send_message(chat_id, f"❌ Ошибка: {str(e)}")

